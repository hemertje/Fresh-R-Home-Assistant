# Kopieer naar deploy.local.env en vul in (staat in .gitignore).
#   cp scripts/deploy.local.env.example scripts/deploy.local.env
#
# Wordt gelezen door scripts/smb_deploy_to_ha.sh (alle projecten) en deploy_to_ha_smb.sh (alleen Fresh-R wrapper).

export SMB_USER="hemertje"
export SMB_PASS="zet_hier_je_smb_wachtwoord"

export HA_HOST="192.168.2.5"
export SHARE="config"

# Veel SMB-clients kunnen geen .../fresh_r/icons map maken. Standaard wordt icons/ overgeslagen.
# export SMB_DEPLOY_INCLUDE_ICONS=1   # toch proberen (meestal niet nodig voor HA)

# Standaard deploy gebruikt tar (fallback: ditto, cp). Forceer rsync-modus:
# export SMB_DEPLOY_COPY=rsync
# Bij rsync op Mac + SMB: bij Permission denied / unlinkat:
# export SMB_RSYNC_NO_DELETE=1
# Of: smb_deploy_to_ha.sh --rsync --no-delete --src ... --dst ...

# Optioneel: voor één repo vaste paden (dan kun je smb_deploy_to_ha.sh zonder args draaien
# als je onderstaande exporteert — normaal geef je --src/--dst op de commandline)
# export DEPLOY_SRC="$HOME/project/custom_components/foo"
# export DEPLOY_DST="custom_components/foo"
