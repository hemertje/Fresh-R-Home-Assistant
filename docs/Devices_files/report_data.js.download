                    "request_date_end": dateEnd,
                    "fields": ["date","t1","t2","t3","t4","flow","co2","hum","dp","temp"]
                }
            }
        }
        //var endpoint = "https://dashboard.bw-log.com/api.php?q=" + JSON.stringify(request);
        var endpoint = "http://vaven.nl/avg_data?serial=" + device+ "&request=forward-sum-day&datefrom=" + dateStart+"&dateto="+dateEnd+"&token="+"a40fd145befdc0093d3945f8f65a1ee62d842ef9f2e1b4b0364b9b082793d39f";
        
        //console.log("http://vaven.nl/forward_data.php?serial=19110001&to=2020-03-05&from=2020-03-04");
        var data = d3.json(endpoint, {
