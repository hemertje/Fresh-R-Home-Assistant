        var endpoint = "https://dashboard.bw-log.com/api.php?q=" + JSON.stringify(request);
        
        var data = d3.json(endpoint, {
            method: "POST"
        });  
  
    } else if (general.page == "forward") {
        request = {
            "token": "a40fd145befdc0093d3945f8f65a1ee62d842ef9f2e1b4b0364b9b082793d39f",
            "tzoffset": timezoneOffset,
            "requests": {
                "data-totals": {
