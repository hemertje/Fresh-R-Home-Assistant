        });
       
        
    }
    else if (general.page == "monitor")  {
        console.log('test');
        
        request = "device_id=" + device + "&to=" + dateEnd+ "&from=" + dateStart;
        //http://vaven.nl/monitor_vaven.php?device_id=47&to=2019-11-09&from=2019-11-08
        
