function yAxis(settings, chartSelection, Yscale, suffix) {

    chartSelection.append("g")
    .classed('y axis', true)
    .call(d3.axisLeft(Yscale).ticks(5).tickFormat(function(d) { return d + suffix; }))
    .append("text")
    .attr("transform", "rotate(-90)")
    .attr("y", 6)
    .attr("dy", "-2.5em")
    .attr("class", "chart-text")
    .attr("text-anchor", "end")
    .text(settings.vertLabel);
}

function xAxis(settings, chartSelection, Xscale, onReportPage) {

    if(onReportPage) {
        var axis = d3.axisBottom(Xscale).ticks(8);

        chartSelection.append("g")
        .attr('transform', 'translate(0,' + settings.linearMaxY + ')')
        .classed('x axis', true)
        .call(axis)
        .append("text")
        .attr("class", "tick")
        .attr("x", settings.linearWidth)
        .attr("y", "1em")
        .attr("style", "text-anchor: end;");

    } else {
        
        var axis = d3.axisBottom(Xscale).ticks(d3.timeHour.every(6)).tickFormat(d3.timeFormat('%H'));
    
        chartSelection.append("g")
        .attr('transform', 'translate(0,' + settings.linearMaxY + ')')
        .classed('x axis', true)
        .call(axis)
        .append("text")
        .attr("class", "tick")
        .attr("x", settings.linearWidth)
        .attr("y", "1em")
        .attr("style", "text-anchor: end;")
        .text("24");  
    }
}

function linPath(xScale, yScale, pathName) {

    var path = d3.line()
        .defined(function(d) { 
            return (d.value[pathName] != -10000) ? true : false; 
        })
        .x(function(d) { return xScale(d.value.time); })
        .y(function(d) { return yScale(d.value[pathName]); })
        .curve(d3.curveMonotoneX);

    return path;
}

function linArea(settings, yScale, domain, path, pathTwo) {
    if(settings.twoPaths) {

        if(settings.attachAreaToSecondPath) {
            var area = d3.area()
            .defined(path.defined())
            .x0(path.x())
            .x1(pathTwo.x())
            .y1(path.y())
            .y0(pathTwo.y())
            .curve(d3.curveMonotoneX);
            return area;
        } 
    }

    var area = d3.area()
    .defined(path.defined())
    .x(path.x())
    .y1(path.y())
    .y0(yScale(domain.min))
    .curve(d3.curveMonotoneX);

    return area;
}



/**
 * Create tooltip elements
 */
function drawLinearHighlights(settings, chartSelection, data, scale, onReportPage, pathName, pathNameTwo) {
    var chartWidth = chartSelection.node().getBBox()["width"];
    var highlightWidth = chartWidth / data.length;
    
    var highlights = chartSelection.selectAll(".highlight")
    .data(data)
    .enter().append("g")
    .attr("class", "highlight");

    for(var i = 0; i < settings.chartContent.length; i++) {
        if(settings.chartContent[i].tipColor !== undefined) {
            highlights.append("circle")
            .attr("class", "highlight-surface")
            .attr("data-html2canvas-ignore",true)
            .attr("r", "10")
            .attr("fill", settings.chartContent[i].tipColor)
            .attr("cx", function(d) { return scale.xScale(d.value.time); })
            .attr("cy", function(d) { return scale.yScale(d.value[settings.chartContent[i].data]); })
        }

        if(settings.chartContent[i].tipText !== undefined) {

            highlights.append("text")
            .attr("class", "tip")
            .attr("data-html2canvas-ignore",true)
            .attr("fill", "grey")
            .text(function(d) { return d.value[settings.chartContent[i].data] + settings.chartContent[i].tipText})
            .attr("x", function(d) {

                return scale.xScale(d.value.time) + 30;
            })
            .attr("style","text-anchor: start;")
            .attr("y", function(d) {
                return scale.yScale(d.value[settings.chartContent[i].data]) - 30;
            });
        }
    }

    highlights.append("text")
    .attr("class", "tip tip-time")
    .attr("data-html2canvas-ignore",true)
    .text(function(d) { 
        
        if(onReportPage) {
            return general.formatDate(d.value.time);
        }

        return general.formatTime(d.value.time);
    })
    .attr("x", function(d, i) { return scale.xScale(d.value.time); })
    .attr("y", settings.linearMaxY + 55);

    //console.log(highlightWidth);

    // highlights.append("rect")
    // .attr("x", function(d) { return scale.xScale(d.value.time) - (highlightWidth/2); })
    // .attr("class", "highlight-surface")
    // .attr("y", 0)
    // .attr("width", highlightWidth)
    // .attr("height", settings.linearMaxY);
}

function createLinearChart(data, settings, targetElement, onReportPage) {

    try {
        if(onReportPage)var dataTotals = data["data-totals"].total;
         else var dataTotals = data["data-totals"][0];
    } catch (error) {
        
        var dataTotals = {
            CO2Removed:0,
            loss:0,
            mv75Loss:0,
            totalFlow:0
        }
        
    }
    
    if(general.page == "fresh-r") {
        data = data["chart-data"];
    }
   
    if(onReportPage) {
        var minTime = new Date(data[0].time);
        minTime.setHours(0,0,0,0);

        var maxTime = new Date(data[data.length - 1].time);

    } else {
        if(general.page == "forward" || general.page == "monitor") {
            data = data["chart-data"];
        }

        var minTime = new Date(data[0].date);
        minTime.setHours(0,0,0,0);

        var maxTime = new Date(data[0].date);
        maxTime.setHours(23,59,59,999);
    }
    console.log("minTime",minTime);
    console.log("maxTime",maxTime);

    var svg = createLinSvg(settings, targetElement, onReportPage);

    svg.selectAll("path, area, g").remove();

    var linearData = genLinearData(settings, data, minTime);
   
    var domain = determineLinDomain(settings, linearData);

    var scale = determineLinScale(settings, domain, minTime, maxTime);

    svg.datum(linearData);

    var content = {}
    var cnt = 0;
    for(var i = 0; i < settings.chartContent.length; i++) {

        content[settings.chartContent[i].data + "_line"] = linPath(scale.xScale, scale.yScale, settings.chartContent[i].data)
        
        if(settings.chartContent[i].type == "line") {

            if(settings.chartContent[i].striped) {

                svg.append("path")
                .attr("class", "line path-one")
                .attr("d", content[settings.chartContent[i].data + "_line"])
                .attr("fill", "transparent")
                .attr("stroke", settings.chartContent[i].strokeColor)
                .style("stroke-width", settings.chartContent[i].strokeWidth)
                .style("stroke-dasharray", ("5, 5"));
    
            } else {
                
                svg.append("path")
                .attr("class", "line path-one")
                .attr("d", content[settings.chartContent[i].data + "_line"])
                .attr("fill", "transparent")
                .attr("stroke", settings.chartContent[i].strokeColor)
                .style("stroke-width", settings.chartContent[i].strokeWidth);
            }
        } else {

            if(settings.chartContent[i].attachTo == null) {
                var area = linArea(settings, scale.yScale, domain, content[settings.chartContent[i].data + "_line"]);
            } else {
                var attachIndex = settings.chartContent.findIndex(content => content.data == settings.chartContent[i].attachTo);
                var area = linArea(settings, scale.yScale, domain, content[settings.chartContent[i].data + "_line"], content[settings.chartContent[attachIndex].data + "_line"]);
            }

            svg.append("path")
            .attr("class", "area")
            .attr("id","area_"+i)
            .attr("style", "fill: " + settings.chartContent[i].areaColor)
            .attr("d", area);

        } 
    }
    
    appendTopLabels(settings, svg, dataTotals, onReportPage);

    yAxis(settings, svg, scale.yScale, "");
    xAxis(settings, svg, scale.xScale, onReportPage);
    drawLinearHighlights(settings, svg, linearData, scale, onReportPage, "lin", "linTwo");
    

}



function attachLinearEventListeners() {

    //tooltip event listeners
    $(".linear-chart").unbind("touchmove");

    $(".highlight-surface, .tip-time").unbind("mouseenter");
    $(".highlight-surface, .tip-time").on("mouseenter", function() {
        $(this).parent().addClass("active");
    });
    $(".highlight-surface, .tip-time").unbind("mouseleave");
    $(".highlight-surface, .tip-time").on("mouseleave", function() {
        $(this).parent().removeClass("active");
    });
    
    //tooltip event listeners for touchscreeen

    $(".linear-chart").unbind("touchmove");
    $(".linear-chart").on("touchmove", function (event) {
        
        event.preventDefault();

        var touch = event.originalEvent.touches[0] || event.originalEvent.changedTouches[0];
        var elem = document.elementFromPoint(touch.clientX, touch.clientY);
        $('svg, .highlight').removeClass('active');
        $(elem).parent().addClass("active");
    });
    
    $(".linear-chart").unbind("touchend");
    $(".linear-chart").on("touchend", function(event) {

        event.preventDefault();

        $('svg, .highlight').removeClass('active');
    });
}