function createLinSvg(settings, targetElement, onReportPage) {

    if(onReportPage) {
        var viewboxY = '-80';
        var viewboxY2 = '260';
        var viewboxX2 = '1720';
        var Backgroundcolor = "none";
        //if(settings.chartContent[0].data=="avg")var viewboxY = '40';
    } else {
        var viewboxY = '-90';
        var viewboxY2 = settings.viewboxY2[0].value;
        var viewboxX2 = settings.viewboxY2[0].value2;
        var Backgroundcolor = "none";
        //var viewboxY = '600';
    }

    var svg = d3.select(targetElement)
   .classed("svg-container", true) //container class to make it responsive
   .append("svg")
   //responsive SVG needs these 2 attributes and no width and height attr
   .attr("preserveAspectRatio", "xMinYMin meet")
   .attr("style", "background-color: "+Backgroundcolor+";width: 100%;height: 100%;")
   .attr("viewBox", "-120 "+viewboxY+" "+viewboxX2+" "+viewboxY2+"")
   //class to make it responsive
   .classed("svg-content-responsive", true); 

   var polar = $('.svg-container');
   $(targetElement).children().attr("width", polar.width()).attr("height", polar.height())

    return svg;
}



function updateLinGradient(svg, id, colorStart, colorEnd) {

    var thermalGradient = svg.append("linearGradient")
    .attr("y1", 0)
    .attr("y2", general.linearMaxY)
    .attr("x1", "0")
    .attr("x2", "0")
    .attr("id", id)
    .attr("gradientUnits", "userSpaceOnUse");

    thermalGradient.append("stop")
    .attr("offset", "0")
    .attr("stop-color", colorStart);

    thermalGradient.append("stop")
    .attr("offset", "1")
    .attr("stop-color", colorEnd);
}

function timeSnap(t, interval, minTimeValue) {
    return new Date(Math.round((t - minTimeValue) / interval) * interval + minTimeValue);
}
function genLinearData(settings, data, minTime) {

    var linearData = d3.nest()
    .key(function(d) { return timeSnap(d.time, general.linearInterval, minTime.valueOf()) })
    .rollup(function(a) {

        var twentyMinData = {
            "time": timeSnap(a[0].time, general.linearInterval, minTime.valueOf())
        };

        for(var i = 0; i < settings.chartContent.length; i++) {

            if(settings.chartContent[i].defaultValue == null) {
                
                var count = 0;
                var sum = 0;
            
                a.forEach(function(measurement) {

                    if(measurement[settings.chartContent[i].data] != -10000) {
                        count++;
                        sum += measurement[settings.chartContent[i].data];
                    }
                });

                if(count > 0) {
                    twentyMinData[settings.chartContent[i].data] = (sum / count).toFixed(settings.precision);
                } else {
                    twentyMinData[settings.chartContent[i].data] = -10000;
                }

            } else {

                twentyMinData[settings.chartContent[i].data] = settings.chartContent[i].defaultValue;
            }            
        }

        return twentyMinData;
        
    }).entries(data);

    return linearData;
}



function determineLinDomain(settings, linearData) {

    var min = 0;
    var max = 0;

    if(settings.dynamicDomain) {

        var min;
        var max;

        for(var i = 0; i < settings.chartContent.length; i++) {
            min = d3.min(linearData, function(d) {
                if(d.value[settings.chartContent[i].data] != -10000) {
                    var currentMin = Math.min(d.value[settings.chartContent[i].data]);
                    return Math.min(currentMin, min);
                }
            });

            max = d3.max(linearData, function(d) {
                var currentMax = Math.max(d.value[settings.chartContent[i].data]);
                return Math.max(currentMax, max);
            });
        }

        return {min, max}
    } 
    
    min = settings.domainMin;
    max = settings.domainMax;

    return { min, max}
}

function determineLinScale(settings, domain, minTime, maxTime) {

    
    var xScale = d3.scaleTime()
    .domain([minTime, maxTime])
    .range([0, settings.linearWidth]);

    var yScale = d3.scaleLinear()
        .domain([domain.max, domain.min])
        .range([0, settings.linearMaxY]);

    return {xScale, yScale};
}

