function draw_bins_forward(data2) {


    console.log('draw bins');

    var co2_400_600_bin = 0;
    var co2_600_800_bin = 0;
    var co2_800_1000_bin = 0;
    var co2_1000_1200_bin = 0;
    var co2_1200_and_higher_bin = 0;



    var hum_0_20_bin = 0;
    var hum_20_40_bin = 0;
    var hum_40_60_bin = 0;
    var hum_60_80_bin = 0;
    var hum_80_and_higher_bin = 0;



    var t1_minus_15_bin = 0;
    var t1_15_18_bin = 0;
    var t1_19_22_bin = 0;
    var t1_23_25_bin = 0;
    var t1_25_and_higher_bin = 0;





    var dp_minus_10_0_bin = 0;
    var dp_0_10_bin = 0;
    var dp_10_20_bin = 0;
    var dp_20_30_bin = 0;
    var dp_30_and_higher_bin = 0;



    var flow_0_25_bin = 0;
    var flow_50_bin = 0;
    var flow_50_75_bin = 0;
    var flow_75_100_bin = 0;
    var flow_100_and_higher_bin = 0;







    for (let i = 0; i < data2.length; i++) { // days
        for (let j = 0; j < data2[i].length; j++) { // 10-minute intervals

            if (data2[i][j].co2 > 400 && data2[i][j].co2 < 600 || data2[i][j].co2 == 400 || data2[i][j].co2 == 600) {
                co2_400_600_bin++;
            }
            if (data2[i][j].co2 > 600 && data2[i][j].co2 < 800 || data2[i][j].co2 == 800) {
                co2_600_800_bin++;
            }
            if (data2[i][j].co2 > 800 && data2[i][j].co2 < 1000 || data2[i][j].co2 == 1000) {
                co2_800_1000_bin++;
            }
            if (data2[i][j].co2 > 999 && data2[i][j].co2 < 1200 || data2[i][j].co2 == 1200) {
                co2_1000_1200_bin++;
            } else if (data2[i][j].co2 > 1200) {
                co2_1200_and_higher_bin++;
            }

            if (data2[i][j].hum <20 || data2[i][j].hum == 20) {
                hum_0_20_bin++;
            }
            if (data2[i][j].hum > 20 && data2[i][j].hum < 30 || data2[i][j].hum == 30) {
                hum_20_40_bin++;
            }
            if (data2[i][j].hum > 30 && data2[i][j].hum < 50 || data2[i][j].hum == 50) {
                hum_40_60_bin++;
            }
            if (data2[i][j].hum > 50 && data2[i][j].hum < 70 || data2[i][j].hum == 70) {
                hum_60_80_bin++;
            } else if (data2[i][j].hum > 70) {
                hum_80_and_higher_bin++;
            }

            if (data2[i][j].temp < 16 || data2[i][j].temp == 16) {
                t1_minus_15_bin++;
            }
            if (data2[i][j].temp > 16 && data2[i][j].temp < 18 || data2[i][j].temp == 18) {
                t1_15_18_bin++;
            }
            if (data2[i][j].temp > 19 && data2[i][j].temp < 21 || data2[i][j].temp == 21) {
                t1_19_22_bin++;
            }
            if (data2[i][j].temp > 22 && data2[i][j].temp < 25 || data2[i][j].temp == 25) {
                t1_23_25_bin++;
            } else if (data2[i][j].temp > 26) {
                t1_25_and_higher_bin++;
            }

            

           

            

            if (data2[i][j].dp < 0 || data2[i][j].dp == 0) {
                dp_minus_10_0_bin++;
            }
            if (data2[i][j].dp > 0 && data2[i][j].dp < 4 || data2[i][j].dp == 4) {
                dp_0_10_bin++;
            }
            if (data2[i][j].dp > 4 && data2[i][j].dp < 8 || data2[i][j].dp == 8) {
                dp_10_20_bin++;
            }
            if (data2[i][j].dp > 8 && data2[i][j].dp < 12 || data2[i][j].dp == 12) {
                dp_20_30_bin++;
            } else if (data2[i][j].dp > 12) {
                dp_30_and_higher_bin++;
            }
            
            if(data2[i][j].flow >400)data2[i][j].flow = +data2[i][j].flow *0.03;//esp forward
            if(location.search.split('serial=f')[1] != undefined) data2[i][j].flow = data2[i][j].flow/3;//esp forward
            if (data2[i][j].flow < 25 || data2[i][j].flow == 25 ) {
                flow_0_25_bin++;
            }
            if (data2[i][j].flow > 25 && data2[i][j].flow < 40 || data2[i][j].flow == 40) {
                flow_50_bin++;
            }
            if (data2[i][j].flow > 40 && data2[i][j].flow < 55 || data2[i][j].flow == 55) {
                flow_50_75_bin++;
            }
            if (data2[i][j].flow > 55 && data2[i][j].flow < 75 || data2[i][j].flow == 75) {
                flow_75_100_bin++;
            } else if (data2[i][j].flow > 75) {
                flow_100_and_higher_bin++;
            }

        };
    }

    var size = 0; //size = array length
    for (let i = 0; i < data2.length; i++) { // i loop_dates over days
        var size = size + data2[i].length;
        Object.values(data2[i]).forEach(val => {



        });
