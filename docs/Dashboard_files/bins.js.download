function draw_bins(data2) {

    var co2_400_600_bin = 0;
    var co2_600_800_bin = 0;
    var co2_800_1000_bin = 0;
    var co2_1000_1200_bin = 0;
    var co2_1200_and_higher_bin = 0;

    var hum_0_20_bin = 0;
    var hum_20_40_bin = 0;
    var hum_40_60_bin = 0;
    var hum_60_80_bin = 0;
    var hum_80_and_higher_bin = 0;

    var rdp_0_20_bin = 0;
    var rdp_20_40_bin = 0;
    var rdp_40_60_bin = 0;
    var rdp_60_80_bin = 0;
    var rdp_80_and_higher_bin = 0;

    var t1_minus_15_bin = 0;
    var t1_15_18_bin = 0;
    var t1_19_22_bin = 0;
    var t1_23_25_bin = 0;
    var t1_25_and_higher_bin = 0;



    var t2_minus_10_0_bin = 0;
    var t2_0_10_bin_ = 0;
    var t2_10_20_bin = 0;
    var t2_20_30_bin = 0;
    var t2_30_and_higher = 0;



    var dp_minus_10_0_bin = 0;
    var dp_0_10_bin = 0;
    var dp_10_20_bin = 0;
    var dp_20_30_bin = 0;
    var dp_30_and_higher_bin = 0;



    var flow_0_25_bin = 0;
    var flow_50_bin = 0;
    var flow_50_75_bin = 0;
    var flow_75_100_bin = 0;
    var flow_100_and_higher_bin = 0;



    var d1_0_25_bin = 0;
    var d1_25_50_bin = 0;
    var d1_50_75_bin = 0;
    var d1_75_100_bin = 0;
    var d1_100_and_higher = 0;
    var d1_filter = false;



    var d4_0_25_bin = 0;
    var d4_25_50_bin = 0;
    var d4_50_75_bin = 0;
    var d4_75_100_bin = 0;
    var d4_100_and_higher_bin = 0;
    var d4_filter = false;



    var d5_0_25_bin = 0;
    var d5_25_50_bin = 0;
    var d5_50_75_bin = 0;
    var d5_75_100_bin = 0;
    var d5_100_and_higher_bin = 0;
    var d5_filter = false;




    for (let i = 0; i < data2.length; i++) { // days
        for (let j = 0; j < data2[i].length; j++) { // 10-minute intervals
            rdp = calculate_rdp(data2[i][j].dp, data2[i][j].t1, data2[i][j].t2);

            if (data2[i][j].co2 > 400 && data2[i][j].co2 < 600 || data2[i][j].co2 == 400 || data2[i][j].co2 == 600) {
                co2_400_600_bin++;
            }
            if (data2[i][j].co2 > 600 && data2[i][j].co2 < 800 || data2[i][j].co2 == 800) {
                co2_600_800_bin++;
            }
            if (data2[i][j].co2 > 800 && data2[i][j].co2 < 1000 || data2[i][j].co2 == 1000) {
                co2_800_1000_bin++;
            }
            if (data2[i][j].co2 > 999 && data2[i][j].co2 < 1200 || data2[i][j].co2 == 1200) {
                co2_1000_1200_bin++;
            } else if (data2[i][j].co2 > 1200) {
                co2_1200_and_higher_bin++;
            }

            if (data2[i][j].hum <20 || data2[i][j].hum == 20) {
                hum_0_20_bin++;
            }
            if (data2[i][j].hum > 20 && data2[i][j].hum < 30 || data2[i][j].hum == 30) {
                hum_20_40_bin++;
            }
            if (data2[i][j].hum > 30 && data2[i][j].hum < 50 || data2[i][j].hum == 50) {
                hum_40_60_bin++;
            }
            if (data2[i][j].hum > 50 && data2[i][j].hum < 70 || data2[i][j].hum == 70) {
                hum_60_80_bin++;
            } else if (data2[i][j].hum > 70) {
                hum_80_and_higher_bin++;
            }

            if (rdp <=20) {
                rdp_0_20_bin++;
            }
            if (rdp > 20 && rdp <= 40) {
                rdp_20_40_bin++;
            }
            if (rdp > 40 && rdp <= 60) {
                rdp_40_60_bin++;
            }
            if (rdp > 60 && rdp <= 80) {
                rdp_60_80_bin++;
            } else if (rdp > 80) {
                rdp_80_and_higher_bin++;
            }

            if (data2[i][j].t1 < 16 || data2[i][j].t1 == 16) {
                t1_minus_15_bin++;
            }
            if (data2[i][j].t1 > 16 && data2[i][j].t1 < 18 || data2[i][j].t1 == 18) {
                t1_15_18_bin++;
            }
            if (data2[i][j].t1 > 19 && data2[i][j].t1 < 21 || data2[i][j].t1 == 21) {
                t1_19_22_bin++;
            }
            if (data2[i][j].t1 > 22 && data2[i][j].t1 < 25 || data2[i][j].t1 == 25) {
                t1_23_25_bin++;
            } else if (data2[i][j].t1 > 26) {
                t1_25_and_higher_bin++;
            }

            if (data2[i][j].t2 < 0 || data2[i][j].t2 == 0) {
                t2_minus_10_0_bin++;
            }
            if (data2[i][j].t2 > 0 && data2[i][j].t2 <= 10) {
                t2_0_10_bin_++;
            }
            if (data2[i][j].t2 > 10 && data2[i][j].t2 <= 17) {
                t2_10_20_bin++;
            }
            if (data2[i][j].t2 > 17 && data2[i][j].t2 <= 24) {
                t2_20_30_bin++;
            } else if (data2[i][j].t2 > 24) {
                t2_30_and_higher++;
            }

            if (data2[i][j].d1_25 > 0) d1_filter = true;
            if (data2[i][j].d1_25 > 0 && data2[i][j].d1_25 < 25 || data2[i][j].d1_25 == 0 || data2[i][j].d1_25 == 25) {
                d1_0_25_bin++;
            }
            if (data2[i][j].d1_25 > 25 && data2[i][j].d1_25 < 50 || data2[i][j].d1_25 == 50) {
                d1_25_50_bin++;
            }
            if (data2[i][j].d1_25 > 50 && data2[i][j].d1_25 < 75 || data2[i][j].d1_25 == 75) {
                d1_50_75_bin++;
            }
            if (data2[i][j].d1_25 > 75 && data2[i][j].d1_25 < 100 || data2[i][j].d1_25 == 100) {
                d1_75_100_bin++;
            } else if (data2[i][j].d1_25 > 100) {
                d1_100_and_higher++;
            }

            if (data2[i][j].d4_25 > 0) d4_filter = true;
            if (data2[i][j].d4_25 > 0 && data2[i][j].d4_25 < 25 || data2[i][j].d4_25 == 0 || data2[i][j].d4_25 == 25) {
                d4_0_25_bin++;
            }
            if (data2[i][j].d4_25 > 25 && data2[i][j].d4_25 < 50 || data2[i][j].d4_25 == 50) {
                d4_25_50_bin++;
            }
            if (data2[i][j].d4_25 > 50 && data2[i][j].d4_25 < 75 || data2[i][j].d4_25 == 75) {
                d4_50_75_bin++;
            }
            if (data2[i][j].d4_25 > 75 && data2[i][j].d4_25 < 100 || data2[i][j].d4_25 == 100) {
                d4_75_100_bin++;
            } else if (data2[i][j].d4_25 > 100) {
                d4_100_and_higher_bin++;
            }

            if (data2[i][j].dp < 0 || data2[i][j].dp == 0) {
                dp_minus_10_0_bin++;
            }
            if (data2[i][j].dp > 0 && data2[i][j].dp < 4 || data2[i][j].dp == 4) {
                dp_0_10_bin++;
            }
            if (data2[i][j].dp > 4 && data2[i][j].dp < 8 || data2[i][j].dp == 8) {
                dp_10_20_bin++;
            }
            if (data2[i][j].dp > 8 && data2[i][j].dp < 12 || data2[i][j].dp == 12) {
                dp_20_30_bin++;
            } else if (data2[i][j].dp > 12) {
                dp_30_and_higher_bin++;
            }
            if (data2[i][j].d5_25 > 0) d5_filter = true;
            if (data2[i][j].d5_25 > 0 && data2[i][j].d5_25 < 25 || data2[i][j].d5_25 == 0 || data2[i][j].d5_25 == 25) {
                d5_0_25_bin++;
            }
            if (data2[i][j].d5_25 > 25 && data2[i][j].d5_25 < 50 || data2[i][j].d5_25 == 50) {
                d5_25_50_bin++;
            }
            if (data2[i][j].d5_25 > 50 && data2[i][j].d5_25 < 75 || data2[i][j].d5_25 == 75) {
                d5_50_75_bin++;
            }
            if (data2[i][j].d5_25 > 75 && data2[i][j].d5_25 < 100 || data2[i][j].d5_25 == 100) {
                d5_75_100_bin++;
            } else if (data2[i][j].d5_25 > 100) {
                d5_100_and_higher_bin++;
            }

            if(data2[i][j].flow >400)data2[i][j].flow = +data2[i][j].flow *0.03;

            if (data2[i][j].flow < 25 || data2[i][j].flow == 25 ) {
                flow_0_25_bin++;
            }
            if (data2[i][j].flow > 25 && data2[i][j].flow < 40 || data2[i][j].flow == 40) {
                flow_50_bin++;
            }
            if (data2[i][j].flow > 40 && data2[i][j].flow < 55 || data2[i][j].flow == 55) {
                flow_50_75_bin++;
            }
            if (data2[i][j].flow > 55 && data2[i][j].flow < 75 || data2[i][j].flow == 75) {
                flow_75_100_bin++;
            } else if (data2[i][j].flow > 75) {
                flow_100_and_higher_bin++;
            }

        };
    }

    var size = 0; //size = array length
    for (let i = 0; i < data2.length; i++) { // i loop_dates over days
        var size = size + data2[i].length;
        Object.values(data2[i]).forEach(val => {



        });
    }



    co2_400_600_bin = Math.round(100 / size * co2_400_600_bin);
    co2_600_800_bin = Math.round(100 / size * co2_600_800_bin);
    co2_800_1000_bin = Math.round(100 / size * co2_800_1000_bin);
    co2_1000_1200_bin = Math.round(100 / size * co2_1000_1200_bin);
    co2_1200_and_higher_bin = Math.round(100 / size * co2_1200_and_higher_bin);



    hum_0_20_bin = Math.round(100 / size * hum_0_20_bin)
    hum_20_40_bin = Math.round(100 / size * hum_20_40_bin)
    hum_40_60_bin = Math.round(100 / size * hum_40_60_bin)
    hum_60_80_bin = Math.round(100 / size * hum_60_80_bin)
    hum_80_and_higher_bin = Math.round(100 / size * hum_80_and_higher_bin)

    rdp_0_20_bin = Math.round(100 / size * rdp_0_20_bin)
    rdp_20_40_bin = Math.round(100 / size * rdp_20_40_bin)
    rdp_40_60_bin = Math.round(100 / size * rdp_40_60_bin)
    rdp_60_80_bin = Math.round(100 / size * rdp_60_80_bin)
    rdp_80_and_higher_bin = Math.round(100 / size * rdp_80_and_higher_bin)



    t1_minus_15_bin = Math.round(100 / size * t1_minus_15_bin)
    t1_15_18_bin = Math.round(100 / size * t1_15_18_bin)
    t1_19_22_bin = Math.round(100 / size * t1_19_22_bin)
    t1_23_25_bin = Math.round(100 / size * t1_23_25_bin)
    t1_25_and_higher_bin = Math.round(100 / size * t1_25_and_higher_bin)



    t2_minus_10_0_bin = Math.round(100 / size * t2_minus_10_0_bin)
    t2_0_10_bin_ = Math.round(100 / size * t2_0_10_bin_)
    t2_10_20_bin = Math.round(100 / size * t2_10_20_bin)
    t2_20_30_bin = Math.round(100 / size * t2_20_30_bin)
    t2_30_and_higher = Math.round(100 / size * t2_30_and_higher)



    dp_minus_10_0_bin = Math.round(100 / size * dp_minus_10_0_bin)
    dp_0_10_bin = Math.round(100 / size * dp_0_10_bin)
    dp_10_20_bin = Math.round(100 / size * dp_10_20_bin)
    dp_20_30_bin = Math.round(100 / size * dp_20_30_bin)
    dp_30_and_higher_bin = Math.round(100 / size * dp_30_and_higher_bin)



    d1_0_25_bin = Math.round(100 / size * d1_0_25_bin)
    d1_25_50_bin = Math.round(100 / size * d1_25_50_bin)
    d1_50_75_bin = Math.round(100 / size * d1_50_75_bin)
    d1_75_100_bin = Math.round(100 / size * d1_75_100_bin)
    d1_100_and_higher = Math.round(100 / size * d1_100_and_higher)



    d4_0_25_bin = Math.round(100 / size * d4_0_25_bin)
    d4_25_50_bin = Math.round(100 / size * d4_25_50_bin)
    d4_50_75_bin = Math.round(100 / size * d4_50_75_bin)
    d4_75_100_bin = Math.round(100 / size * d4_75_100_bin)
    d4_100_and_higher_bin = Math.round(100 / size * d4_100_and_higher_bin)



    d5_0_25_bin = Math.round(100 / size * d5_0_25_bin)
    d5_25_50_bin = Math.round(100 / size * d5_25_50_bin)
    d5_50_75_bin = Math.round(100 / size * d5_50_75_bin)
    d5_75_100_bin = Math.round(100 / size * d5_75_100_bin)
    d5_100_and_higher_bin = Math.round(100 / size * d5_100_and_higher_bin)



    flow_0_25_bin = Math.round(100 / size * flow_0_25_bin)
    flow_50_bin = Math.round(100 / size * flow_50_bin)
    flow_50_75_bin = Math.round(100 / size * flow_50_75_bin)
    flow_75_100_bin = Math.round(100 / size * flow_75_100_bin)
    flow_100_and_higher_bin = Math.round(100 / size * flow_100_and_higher_bin)



