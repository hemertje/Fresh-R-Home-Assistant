function calculate_rdp(dp, t1, t2) {
    if (t1 === t2) {
        if(dp>t2) return 100;
        return 0;
    }
    
    let rdp = ((dp - t2) / (t1 - t2)) * 100;
    rdp = Math.max(0, Math.min(100, rdp))
    return rdp;
}