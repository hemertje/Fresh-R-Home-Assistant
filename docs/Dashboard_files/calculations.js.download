function generatePDF() { //set the settings and generates the pdf file. (downloaded with download pdf button on site.)
    const element = document.getElementById("pdf"); //gets the element name from the DIV called pdf
    var opt = {
        margin: 2,
        html2canvas: {
            scale: 1
        },
        jsPDF: {
            orientation: 'portrait',
            unit: 'cm',
            format: 'A4'
        },
        // pagebreak: {
        //     mode: 'avoid-all',
        //     after: ['#dew', '#flow']
        // }
    };
    html2pdf()
        .set(opt)
        .from(element)
        .save("Table"); //saves the pdf as "Table.pdf"
}

function data_10_seconds(serial, start, end) { // gets the data from every day filled in the date boxes 
    // when nothing filled in it set the dates to today
    var cookies = getCookies();
    var token = cookies["sess_token"]; 
    var start = new Date(start);
    var end = new Date(end);
    var loop_date = new Date(start);
    var data2 = new Array();
    var count = 0;
    while (loop_date <= end) {

    var date = formatDate(loop_date);
    request = {
    "tzoffset": 60,
    "token": token,
    "requests": {
    "chart-data": {
    "request": "fresh-r-day",
    "request_date": date,
    "serial": serial,
    "fields": [
    "date",
    "co2",
    "hum",
    "d5_25",
    "d4_25",
    "d1_25",
    "t1",
    "t2",
    "t3",
    "dp",
    "flow",
    "t4",
    "fan1",
    "fan2",
    "tbal",
    "mode"
    ]
    }
    }
    }
    var endpoint = "https://dashboard.bw-log.com/testdata-api.php?q=" + JSON.stringify(request);

    $.ajax({
    url: endpoint,
    async: false, // tells browser to wait for reply
    type: 'post',
    dataType: "json",
    success: function(output) {
    data = output;
    data2[count] = output["chart-data"];
    }
    });


    var newDate = loop_date.setDate(loop_date.getDate() + 1);
    loop_date = new Date(newDate);
    count++; //number of days
    }
    ////console.log(data2); //array
    var start_interval = new Date(data2[0][0].date); // first moment of data range 
    var days = data2.length;
    var records = data2[days - 1].length;
    var end_interval = new Date(data2[days - 1][records - 1].date);
    var interval = (end_interval - start_interval) / 1000; // default is milliseconds

    ////console.log(start_interval)     //start date
    ////console.log(end_interval)       //end date

    return [data2, interval];
}

