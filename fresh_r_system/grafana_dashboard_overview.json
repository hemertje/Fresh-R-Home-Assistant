{
  "dashboard": {
    "title": "Fresh-R Ventilatie - Overzicht",
    "tags": ["fresh-r", "ventilation", "air-quality"],
    "timezone": "Europe/Amsterdam",
    "schemaVersion": 36,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "device",
          "type": "query",
          "query": "SHOW TAG VALUES FROM \"fresh_r\" WITH KEY = \"device\"",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "🌡️ Temperaturen",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "fresh_r_t1{device=~\"$device\"}",
            "legendFormat": "Binnen",
            "refId": "A"
          },
          {
            "expr": "fresh_r_t2{device=~\"$device\"}",
            "legendFormat": "Buiten",
            "refId": "B"
          },
          {
            "expr": "fresh_r_t3{device=~\"$device\"}",
            "legendFormat": "Toevoer",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "min": -10,
            "max": 40,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": -10},
                {"color": "green", "value": 18},
                {"color": "yellow", "value": 25},
                {"color": "red", "value": 30}
              ]
            },
            "custom": {
              "neutral": 20
            }
          }
        }
      },
      {
        "id": 2,
        "title": "💨 CO2 Niveau",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
        "targets": [
          {
            "expr": "fresh_r_co2{device=~\"$device\"}",
            "legendFormat": "CO2",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ppm",
            "min": 400,
            "max": 2000,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 400},
                {"color": "yellow", "value": 800},
                {"color": "orange", "value": 1200},
                {"color": "red", "value": 1500}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "💧 Luchtvochtigheid",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
        "targets": [
          {
            "expr": "fresh_r_hum{device=~\"$device\"}",
            "legendFormat": "RV",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 30},
                {"color": "green", "value": 40},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 80}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "🌫️ PM2.5 Fijnstof",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "fresh_r_d5_25{device=~\"$device\"}",
            "legendFormat": "Toevoer",
            "refId": "A"
          },
          {
            "expr": "fresh_r_d4_25{device=~\"$device\"}",
            "legendFormat": "Buiten",
            "refId": "B"
          },
          {
            "expr": "fresh_r_d1_25{device=~\"$device\"}",
            "legendFormat": "Binnen",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "µg/m³"
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "textMode": "auto"
        }
      },
      {
        "id": 5,
        "title": "🌫️ PM1.0 Fijnstof",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "fresh_r_d5_1{device=~\"$device\"}",
            "legendFormat": "Toevoer",
            "refId": "A"
          },
          {
            "expr": "fresh_r_d4_1{device=~\"$device\"}",
            "legendFormat": "Buiten",
            "refId": "B"
          },
          {
            "expr": "fresh_r_d1_1{device=~\"$device\"}",
            "legendFormat": "Binnen",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "µg/m³"
          }
        }
      },
      {
        "id": 6,
        "title": "🌫️ PM0.3 Fijnstof",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "fresh_r_d5_03{device=~\"$device\"}",
            "legendFormat": "Toevoer",
            "refId": "A"
          },
          {
            "expr": "fresh_r_d4_03{device=~\"$device\"}",
            "legendFormat": "Buiten",
            "refId": "B"
          },
          {
            "expr": "fresh_r_d1_03{device=~\"$device\"}",
            "legendFormat": "Binnen",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "count"
          }
        }
      },
      {
        "id": 7,
        "title": "🔄 Ventilatie & Energie",
        "type": "stat",
        "gridPos": {"h": 4, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "fresh_r_flow{device=~\"$device\"}",
            "legendFormat": "Debiet (m³/h)",
            "refId": "A"
          },
          {
            "expr": "fresh_r_heat_recovered{device=~\"$device\"}",
            "legendFormat": "Warmteterugwinning (W)",
            "refId": "B"
          },
          {
            "expr": "fresh_r_vent_loss{device=~\"$device\"}",
            "legendFormat": "Ventilatie verlies (W)",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 8,
        "title": "📊 Status Overzicht",
        "type": "table",
        "gridPos": {"h": 4, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "fresh_r_{device=~\"$device\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Time"},
              "properties": [{"id": "custom.displayMode", "value": "date"}]
            }
          ]
        }
      },
      {
        "id": 9,
        "title": "🌡️ Temperatuur Geschiedenis (24h)",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "fresh_r_t1{device=~\"$device\"}",
            "legendFormat": "Binnen (t1)",
            "refId": "A"
          },
          {
            "expr": "fresh_r_t2{device=~\"$device\"}",
            "legendFormat": "Buiten (t2)",
            "refId": "B"
          },
          {
            "expr": "fresh_r_t3{device=~\"$device\"}",
            "legendFormat": "Toevoer (t3)",
            "refId": "C"
          },
          {
            "expr": "fresh_r_t4{device=~\"$device\"}",
            "legendFormat": "Afvoer (t4)",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 3,
              "showPoints": "never",
              "gradientMode": "scheme",
              "lineWidth": 2
            }
          }
        },
        "options": {
          "legend": {
            "calcs": ["mean", "max", "min"],
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 10,
        "title": "💨 Luchtkwaliteit Geschiedenis (24h)",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 26},
        "targets": [
          {
            "expr": "fresh_r_co2{device=~\"$device\"}",
            "legendFormat": "CO2 (ppm)",
            "refId": "A"
          },
          {
            "expr": "fresh_r_hum{device=~\"$device\"}",
            "legendFormat": "Vochtigheid (%)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 3,
              "showPoints": "never"
            }
          }
        }
      },
      {
        "id": 11,
        "title": "🌫️ PM2.5 Geschiedenis (24h)",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 26},
        "targets": [
          {
            "expr": "fresh_r_d5_25{device=~\"$device\"}",
            "legendFormat": "Toevoer PM2.5",
            "refId": "A"
          },
          {
            "expr": "fresh_r_d4_25{device=~\"$device\"}",
            "legendFormat": "Buiten PM2.5",
            "refId": "B"
          },
          {
            "expr": "fresh_r_d1_25{device=~\"$device\"}",
            "legendFormat": "Binnen PM2.5",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "µg/m³",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 3,
              "showPoints": "never",
              "gradientMode": "scheme"
            }
          }
        }
      }
    ]
  }
}
