{
  "dashboard": {
    "title": "Fresh-R Ventilatie - Details",
    "tags": ["fresh-r", "ventilation", "details"],
    "timezone": "Europe/Amsterdam",
    "schemaVersion": 36,
    "refresh": "30s",
    "time": {
      "from": "now-3h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "device",
          "type": "query",
          "query": "SHOW TAG VALUES FROM \"fresh_r\" WITH KEY = \"device\"",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "🌡️ Temperatuur Sensoren",
        "type": "timeseries",
        "gridPos": {"h": 12, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "fresh_r_t1{device=~\"$device\"}",
            "legendFormat": "Binnen (t1)",
            "refId": "A"
          },
          {
            "expr": "fresh_r_t2{device=~\"$device\"}",
            "legendFormat": "Buiten (t2)",
            "refId": "B"
          },
          {
            "expr": "fresh_r_t3{device=~\"$device\"}",
            "legendFormat": "Toevoer (t3)",
            "refId": "C"
          },
          {
            "expr": "fresh_r_t4{device=~\"$device\"}",
            "legendFormat": "Afvoer (t4)",
            "refId": "D"
          },
          {
            "expr": "fresh_r_dp{device=~\"$device\"}",
            "legendFormat": "Dauwpunt (dp)",
            "refId": "E"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 2,
              "showPoints": "auto"
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "calcs": ["mean", "max", "min", "lastNotNull"]
          }
        }
      },
      {
        "id": 2,
        "title": "💨 Luchtkwaliteit Sensoren",
        "type": "timeseries",
        "gridPos": {"h": 12, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "fresh_r_co2{device=~\"$device\"}",
            "legendFormat": "CO2",
            "refId": "A"
          },
          {
            "expr": "fresh_r_hum{device=~\"$device\"}",
            "legendFormat": "Luchtvochtigheid",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 2,
              "showPoints": "auto"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "CO2"},
              "properties": [{"id": "unit", "value": "ppm"}]
            },
            {
              "matcher": {"id": "byName", "options": "Luchtvochtigheid"},
              "properties": [{"id": "unit", "value": "percent"}]
            }
          ]
        }
      },
      {
        "id": 3,
        "title": "🌫️ PM2.5 - Alle Locaties",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 8, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "fresh_r_d1_25{device=~\"$device\"}",
            "legendFormat": "Binnen",
            "refId": "A"
          },
          {
            "expr": "fresh_r_d4_25{device=~\"$device\"}",
            "legendFormat": "Buiten",
            "refId": "B"
          },
          {
            "expr": "fresh_r_d5_25{device=~\"$device\"}",
            "legendFormat": "Toevoer",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "µg/m³",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 2
            }
          }
        }
      },
      {
        "id": 4,
        "title": "🌫️ PM1.0 - Alle Locaties",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 8, "x": 8, "y": 12},
        "targets": [
          {
            "expr": "fresh_r_d1_1{device=~\"$device\"}",
            "legendFormat": "Binnen",
            "refId": "A"
          },
          {
            "expr": "fresh_r_d4_1{device=~\"$device\"}",
            "legendFormat": "Buiten",
            "refId": "B"
          },
          {
            "expr": "fresh_r_d5_1{device=~\"$device\"}",
            "legendFormat": "Toevoer",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "µg/m³",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 2
            }
          }
        }
      },
      {
        "id": 5,
        "title": "🌫️ PM0.3 - Alle Locaties",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 8, "x": 16, "y": 12},
        "targets": [
          {
            "expr": "fresh_r_d1_03{device=~\"$device\"}",
            "legendFormat": "Binnen",
            "refId": "A"
          },
          {
            "expr": "fresh_r_d4_03{device=~\"$device\"}",
            "legendFormat": "Buiten",
            "refId": "B"
          },
          {
            "expr": "fresh_r_d5_03{device=~\"$device\"}",
            "legendFormat": "Toevoer",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "count",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 2
            }
          }
        }
      },
      {
        "id": 6,
        "title": "🔄 Ventilatie Debiet",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
        "targets": [
          {
            "expr": "fresh_r_flow{device=~\"$device\"}",
            "legendFormat": "Debiet (m³/h)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "m3/h",
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 20,
              "gradientMode": "scheme",
              "pointSize": 2
            }
          }
        }
      },
      {
        "id": 7,
        "title": "⚡ Energie Metrics",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
        "targets": [
          {
            "expr": "fresh_r_heat_recovered{device=~\"$device\"}",
            "legendFormat": "Warmteterugwinning",
            "refId": "A"
          },
          {
            "expr": "fresh_r_vent_loss{device=~\"$device\"}",
            "legendFormat": "Ventilatie verlies",
            "refId": "B"
          },
          {
            "expr": "fresh_r_energy_loss{device=~\"$device\"}",
            "legendFormat": "Energie verlies",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "watt",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "pointSize": 2
            }
          }
        }
      },
      {
        "id": 8,
        "title": "📋 Alle Sensoren - Huidige Waarden",
        "type": "table",
        "gridPos": {"h": 12, "w": 24, "x": 0, "y": 30},
        "targets": [
          {
            "expr": "fresh_r_{device=~\"$device\"}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "displayMode": "auto",
              "inspect": false
            }
          }
        },
        "options": {
          "showHeader": true,
          "sortBy": [
            {"desc": false, "displayName": "Time"}
          ]
        }
      }
    ]
  }
}
