{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB datasource met fresh_r measurement",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Fresh-r ventilatiesysteem — replica van fresh-r.me dashboard",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "liveNow": true,
  "panels": [

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 100, "title": "Actueel", "type": "row"},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},
       "thresholds": {"mode": "absolute", "steps": [
         {"color": "green", "value": null}, {"color": "orange", "value": 1000}, {"color": "red", "value": 1200}
       ]}, "unit": "ppm"}},
     "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1}, "id": 1,
     "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "textMode": "auto"},
     "title": "CO2", "type": "stat",
     "targets": [{"query": "SELECT last(\"co2\") FROM \"fresh_r\" WHERE $timeFilter", "rawQuery": true, "refId": "A"}]},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {"defaults": {"color": {"fixedColor": "#ff5722", "mode": "fixed"}, "unit": "celsius"}},
     "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1}, "id": 2,
     "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
     "title": "Binnentemperatuur", "type": "stat",
     "targets": [{"query": "SELECT last(\"t1\") FROM \"fresh_r\" WHERE $timeFilter", "rawQuery": true, "refId": "A"}]},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {"defaults": {"color": {"fixedColor": "#03a9f4", "mode": "fixed"}, "unit": "celsius"}},
     "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1}, "id": 3,
     "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
     "title": "Buitentemperatuur", "type": "stat",
     "targets": [{"query": "SELECT last(\"t2\") FROM \"fresh_r\" WHERE $timeFilter", "rawQuery": true, "refId": "A"}]},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {"defaults": {"color": {"fixedColor": "#2196f3", "mode": "fixed"}, "unit": "none",
       "custom": {"displayName": "m³/h"}}},
     "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1}, "id": 4,
     "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
     "title": "Debiet (m³/h)", "type": "stat",
     "targets": [{"query": "SELECT last(\"flow\") FROM \"fresh_r\" WHERE $timeFilter", "rawQuery": true, "refId": "A"}]},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {"defaults": {"color": {"fixedColor": "#00bcd4", "mode": "fixed"}, "unit": "humidity"}},
     "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1}, "id": 5,
     "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
     "title": "Vochtigheid", "type": "stat",
     "targets": [{"query": "SELECT last(\"hum\") FROM \"fresh_r\" WHERE $timeFilter", "rawQuery": true, "refId": "A"}]},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {"defaults": {"color": {"fixedColor": "#ff9800", "mode": "fixed"}, "unit": "watt"}},
     "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1}, "id": 6,
     "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
     "title": "Warmteterugwinning", "type": "stat",
     "targets": [{"query": "SELECT last(\"heat_recovered\") FROM \"fresh_r\" WHERE $timeFilter", "rawQuery": true, "refId": "A"}]},

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "id": 101, "title": "CO2 & Temperaturen", "type": "row"},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {
       "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10, "spanNulls": false}, "unit": "ppm"},
       "overrides": [
         {"matcher": {"id": "byName", "options": "co2"}, "properties": [
           {"id": "color", "value": {"fixedColor": "#4caf50", "mode": "fixed"}},
           {"id": "thresholds", "value": {"mode": "absolute", "steps": [
             {"color": "green", "value": null}, {"color": "orange", "value": 1000}, {"color": "red", "value": 1200}
           ]}},
           {"id": "custom.thresholdsStyle", "value": {"mode": "line+area"}}
         ]}
       ]
     },
     "gridPos": {"h": 9, "w": 16, "x": 0, "y": 6}, "id": 10,
     "options": {"tooltip": {"mode": "multi", "sort": "none"}, "legend": {"displayMode": "list", "placement": "bottom"}},
     "title": "CO2 (ppm)", "type": "timeseries",
     "targets": [{"query": "SELECT mean(\"co2\") AS \"co2\" FROM \"fresh_r\" WHERE $timeFilter GROUP BY time($__interval) fill(none)", "rawQuery": true, "refId": "A"}]},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {
       "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 8, "spanNulls": false}, "unit": "celsius"},
       "overrides": [
         {"matcher": {"id": "byName", "options": "t1"}, "properties": [{"id": "color", "value": {"fixedColor": "#ff5722", "mode": "fixed"}}, {"id": "displayName", "value": "Binnenlucht"}]},
         {"matcher": {"id": "byName", "options": "t2"}, "properties": [{"id": "color", "value": {"fixedColor": "#03a9f4", "mode": "fixed"}}, {"id": "displayName", "value": "Buitenlucht"}]},
         {"matcher": {"id": "byName", "options": "t3"}, "properties": [{"id": "color", "value": {"fixedColor": "#8bc34a", "mode": "fixed"}}, {"id": "displayName", "value": "Aanvoer"}]},
         {"matcher": {"id": "byName", "options": "t4"}, "properties": [{"id": "color", "value": {"fixedColor": "#9c27b0", "mode": "fixed"}}, {"id": "displayName", "value": "Afvoer"}]}
       ]
     },
     "gridPos": {"h": 9, "w": 8, "x": 16, "y": 6}, "id": 11,
     "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
     "title": "Temperaturen (°C)", "type": "timeseries",
     "targets": [{"query": "SELECT mean(\"t1\") AS \"t1\", mean(\"t2\") AS \"t2\", mean(\"t3\") AS \"t3\", mean(\"t4\") AS \"t4\" FROM \"fresh_r\" WHERE $timeFilter GROUP BY time($__interval) fill(none)", "rawQuery": true, "refId": "A"}]},

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15}, "id": 102, "title": "Debiet & Warmte", "type": "row"},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {"defaults": {"custom": {"lineWidth": 2, "fillOpacity": 20, "spanNulls": false},
       "color": {"fixedColor": "#2196f3", "mode": "fixed"}}},
     "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}, "id": 20,
     "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
     "title": "Luchtdebiet (m³/h)", "type": "timeseries",
     "targets": [{"query": "SELECT mean(\"flow\") AS \"flow\" FROM \"fresh_r\" WHERE $timeFilter GROUP BY time($__interval) fill(none)", "rawQuery": true, "refId": "A"}]},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {
       "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 8, "spanNulls": false}, "unit": "watt"},
       "overrides": [
         {"matcher": {"id": "byName", "options": "heat_recovered"}, "properties": [{"id": "color", "value": {"fixedColor": "#ff9800", "mode": "fixed"}}, {"id": "displayName", "value": "Warmteterugwinning"}]},
         {"matcher": {"id": "byName", "options": "vent_loss"},       "properties": [{"id": "color", "value": {"fixedColor": "#607d8b", "mode": "fixed"}}, {"id": "displayName", "value": "Ref ventilatieverl. (75m³/h)"}]},
         {"matcher": {"id": "byName", "options": "energy_loss"},     "properties": [{"id": "color", "value": {"fixedColor": "#e91e63", "mode": "fixed"}}, {"id": "displayName", "value": "Energieverlies"}]}
       ]
     },
     "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}, "id": 21,
     "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
     "title": "Warmte (W)", "type": "timeseries",
     "targets": [{"query": "SELECT mean(\"heat_recovered\") AS \"heat_recovered\", mean(\"vent_loss\") AS \"vent_loss\", mean(\"energy_loss\") AS \"energy_loss\" FROM \"fresh_r\" WHERE $timeFilter GROUP BY time($__interval) fill(none)", "rawQuery": true, "refId": "A"}]},

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24}, "id": 103, "title": "Vochtigheid & Dauwpunt", "type": "row"},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {
       "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 12, "spanNulls": false}},
       "overrides": [
         {"matcher": {"id": "byName", "options": "hum"}, "properties": [
           {"id": "unit", "value": "percent"}, {"id": "color", "value": {"fixedColor": "#00bcd4", "mode": "fixed"}}, {"id": "displayName", "value": "Vochtigheid %"}]},
         {"matcher": {"id": "byName", "options": "dp"}, "properties": [
           {"id": "unit", "value": "celsius"}, {"id": "color", "value": {"fixedColor": "#9c27b0", "mode": "fixed"}},
           {"id": "displayName", "value": "Dauwpunt °C"}, {"id": "custom.axisPlacement", "value": "right"}]}
       ]
     },
     "gridPos": {"h": 8, "w": 24, "x": 0, "y": 25}, "id": 30,
     "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
     "title": "Vochtigheid & Dauwpunt", "type": "timeseries",
     "targets": [{"query": "SELECT mean(\"hum\") AS \"hum\", mean(\"dp\") AS \"dp\" FROM \"fresh_r\" WHERE $timeFilter GROUP BY time($__interval) fill(none)", "rawQuery": true, "refId": "A"}]},

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33}, "id": 104, "title": "Fijnstof (PM)", "type": "row"},

    {"datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
     "fieldConfig": {
       "defaults": {"custom": {"lineWidth": 2, "fillOpacity": 8, "spanNulls": false}},
       "overrides": [
         {"matcher": {"id": "byName", "options": "d5_25"}, "properties": [{"id": "color", "value": {"fixedColor": "#8bc34a", "mode": "fixed"}}, {"id": "displayName", "value": "Aanvoer PM2.5"}]},
         {"matcher": {"id": "byName", "options": "d4_25"}, "properties": [{"id": "color", "value": {"fixedColor": "#03a9f4", "mode": "fixed"}}, {"id": "displayName", "value": "Buiten PM2.5"}]},
         {"matcher": {"id": "byName", "options": "d1_25"}, "properties": [{"id": "color", "value": {"fixedColor": "#ff5722", "mode": "fixed"}}, {"id": "displayName", "value": "Binnen PM2.5"}]}
       ]
     },
     "gridPos": {"h": 8, "w": 24, "x": 0, "y": 34}, "id": 40,
     "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
     "title": "PM2.5 (µg/m³)", "type": "timeseries",
     "targets": [{"query": "SELECT mean(\"d5_25\") AS \"d5_25\", mean(\"d4_25\") AS \"d4_25\", mean(\"d1_25\") AS \"d1_25\" FROM \"fresh_r\" WHERE $timeFilter GROUP BY time($__interval) fill(none)", "rawQuery": true, "refId": "A"}]}

  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["fresh-r", "ventilatie", "luchtkwaliteit"],
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Fresh-r Dashboard",
  "uid": "fresh-r-main",
  "version": 1
}
